# Python cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local runtime files
*.log
*.pid
*.tmp
*.temp

# Uploaded and shared files
# Keep the folders in the repository with .gitkeep if needed, but do not commit user files.
upload/*
download/*
!upload/.gitkeep
!download/.gitkeep

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/

# Packaging/build output
build/
dist/
*.egg-info/
